# vite-plugin-pwa (latest 1.2.0) declares a peer dep of Vite ^3–^7, but this
# project is on Vite 8. The plugin actually works fine with Vite 8 — the peer
# declaration just hasn't been updated upstream yet. Accept the mismatch here
# so `npm ci` (local + CI) installs cleanly.
legacy-peer-deps=true
